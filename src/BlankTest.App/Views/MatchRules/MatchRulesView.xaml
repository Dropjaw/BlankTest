<UserControl x:Class="BlankTest.App.Views.MatchRules.MatchRulesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="StatusBadgeBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="Background" Value="{StaticResource SuccessSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers><DataTrigger Binding="{Binding IsActive}" Value="False"><Setter Property="Background" Value="{StaticResource DangerSoftBrush}" /><Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" /></DataTrigger></Style.Triggers>
        </Style>
        <Style x:Key="StatusBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" /><Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
            <Style.Triggers><DataTrigger Binding="{Binding IsActive}" Value="False"><Setter Property="Foreground" Value="{StaticResource DangerBrush}" /></DataTrigger></Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions><RowDefinition Height="76" /><RowDefinition Height="112" /><RowDefinition Height="*" /></Grid.RowDefinitions>
        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="704" /></Grid.ColumnDefinitions>
            <StackPanel><TextBlock Text="{Binding PageTitle}" Style="{StaticResource PageTitleTextStyle}" /><TextBlock Text="{Binding PageSubtitle}" Margin="0,8,0,0" Foreground="{StaticResource TextSecondaryBrush}" /></StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <TextBox Width="210" Style="{StaticResource EnterpriseTextBoxStyle}" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Search match rules" ToolTip="Search match rules" />
                <ComboBox Width="128" Margin="16,0,0,0" Style="{StaticResource EnterpriseComboBoxStyle}" ItemsSource="{Binding StatusFilters}" SelectedItem="{Binding SelectedStatusFilter}" DisplayMemberPath="DisplayName" AutomationProperties.Name="Filter match rules by status" />
                <Button Margin="16,0,0,0" Style="{StaticResource SecondaryOutlineButtonStyle}" Command="{Binding ExportCommand}" Content="⇧  Export" AutomationProperties.Name="Export match rules" />
                <Button Margin="16,0,0,0" Style="{StaticResource PrimaryActionButtonStyle}" Command="{Binding CreateMatchRuleCommand}" Content="+  New Match Rule" AutomationProperties.Name="Create new match rule" />
            </StackPanel>
        </Grid>
        <ItemsControl Grid.Row="1" ItemsSource="{Binding MetricCards}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="4" /></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate>
            <Border Style="{StaticResource EnterpriseCardStyle}" Height="100" Padding="20" Margin="0,0,16,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="66" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Border Width="58" Height="58" CornerRadius="29" Background="{StaticResource PrimaryBlueSoftBrush}"><TextBlock Text="{Binding Icon}" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource PrimaryBlueBrush}" /></Border><StackPanel Grid.Column="1" VerticalAlignment="Center"><TextBlock Text="{Binding Title}" FontWeight="SemiBold" /><TextBlock Text="{Binding Value}" FontSize="30" FontWeight="Bold" Foreground="{StaticResource PrimaryBlueBrush}" /></StackPanel></Grid></Border>
        </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
        <Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="390" /></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="150" /></Grid.RowDefinitions>
            <Border Grid.Column="0" Style="{StaticResource EnterpriseCardStyle}" Margin="0,0,16,14"><Grid><Grid.RowDefinitions><RowDefinition Height="52" /><RowDefinition Height="*" /><RowDefinition Height="56" /></Grid.RowDefinitions>
                <TextBlock Text="Match Rule List" Margin="18,16,0,0" Style="{StaticResource SectionTitleTextStyle}" />
                <DataGrid Grid.Row="1" Style="{StaticResource EnterpriseDataGridStyle}" ItemsSource="{Binding PagedMatchRules}" SelectedItem="{Binding SelectedMatchRule, Mode=TwoWay}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Rule Name" Binding="{Binding RuleName}" Width="2*" />
                        <DataGridTextColumn Header="Application" Binding="{Binding ApplicationName}" Width="*" />
                        <DataGridTextColumn Header="Module" Binding="{Binding ModuleName}" Width="1.4*" />
                        <DataGridTextColumn Header="Match Type" Binding="{Binding MatchType}" Width="*" />
                        <DataGridTextColumn Header="Priority" Binding="{Binding Priority}" Width="*" />
                        <DataGridTemplateColumn Header="Status" Width="90"><DataGridTemplateColumn.CellTemplate><DataTemplate><Border Style="{StaticResource StatusBadgeBorderStyle}" AutomationProperties.Name="{Binding Status}"><TextBlock Text="{Binding Status}" Style="{StaticResource StatusBadgeTextStyle}" /></Border></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                        <DataGridTextColumn Header="Last Updated" Binding="{Binding LastUpdatedDisplay}" Width="1.4*" />
                        <DataGridTextColumn Header="Updated By" Binding="{Binding UpdatedBy}" Width="*" />
                        <DataGridTemplateColumn Header="Actions" Width="74"><DataGridTemplateColumn.CellTemplate><DataTemplate><Button Content="⋮" FontSize="18" BorderThickness="0" Background="Transparent" Command="{Binding DataContext.OpenRuleActionsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" AutomationProperties.Name="Open row actions" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <Grid Grid.Row="2" Margin="18,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="{Binding PageSummaryText}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" /><StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"><TextBlock Text="Rows per page:" VerticalAlignment="Center" Margin="0,0,8,0" /><ComboBox Width="68" ItemsSource="{Binding RowsPerPageOptions}" SelectedItem="{Binding RowsPerPage}" Style="{StaticResource EnterpriseComboBoxStyle}" /><Button Content="‹" Width="34" Margin="22,0,4,0" Command="{Binding GoToPreviousPageCommand}" Style="{StaticResource SecondaryOutlineButtonStyle}" /><ItemsControl ItemsSource="{Binding PaginationItems}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><Button Content="{Binding DisplayText}" Width="34" Margin="4,0" Command="{Binding DataContext.ChangePageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource SecondaryOutlineButtonStyle}" /></DataTemplate></ItemsControl.ItemTemplate></ItemsControl><Button Content="›" Width="34" Margin="4,0,0,0" Command="{Binding GoToNextPageCommand}" Style="{StaticResource SecondaryOutlineButtonStyle}" /></StackPanel></Grid>
            </Grid></Border>
            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource EnterpriseCardStyle}" Margin="0,0,16,0" Padding="12"><DockPanel><TextBlock DockPanel.Dock="Top" Text="Quick Actions" Style="{StaticResource SectionTitleTextStyle}" Margin="6,0,0,10" /><ItemsControl ItemsSource="{Binding QuickActions}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="3" /></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><Button Command="{Binding DataContext.OpenQuickActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Padding="0"><Border Style="{StaticResource EnterpriseCardStyle}" Padding="14" Margin="0,0,12,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="52" /><ColumnDefinition Width="*" /><ColumnDefinition Width="18" /></Grid.ColumnDefinitions><Border Width="44" Height="44" CornerRadius="22" Background="{StaticResource PrimaryBlueSoftBrush}"><TextBlock Text="{Binding Icon}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" Foreground="{StaticResource PrimaryBlueBrush}" /></Border><StackPanel Grid.Column="1"><TextBlock Text="{Binding Title}" FontWeight="Bold" /><TextBlock Text="{Binding Description}" FontSize="11" TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" /></StackPanel><TextBlock Grid.Column="2" Text="›" FontSize="24" VerticalAlignment="Center" /></Grid></Border></Button></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></DockPanel></Border>
            <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Style="{StaticResource EnterpriseCardStyle}" Padding="24"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="52" /></Grid.RowDefinitions><TextBlock Text="Match Rule Details" Style="{StaticResource SectionTitleTextStyle}" /><StackPanel Grid.Row="1" Margin="0,22,0,0"><StackPanel Orientation="Horizontal" Margin="0,0,0,20"><Border Width="58" Height="58" CornerRadius="29" Background="{StaticResource PrimaryBlueBrush}"><TextBlock Text="▽" Foreground="White" FontSize="31" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border><TextBlock Text="{Binding SelectedMatchRule.RuleName, TargetNullValue=Select a match rule to view details.}" Margin="16,9,0,0" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" Width="260" /></StackPanel><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="120" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition /></Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Description:" FontWeight="Bold" Margin="0,0,0,12" /><TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedMatchRule.Description}" TextWrapping="Wrap" Margin="0,0,0,12" />
                <TextBlock Grid.Row="1" Text="Application:" FontWeight="Bold" Margin="0,0,0,12" /><TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedMatchRule.ApplicationName}" />
                <TextBlock Grid.Row="2" Text="Module:" FontWeight="Bold" Margin="0,0,0,12" /><TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedMatchRule.ModuleName}" />
                <TextBlock Grid.Row="3" Text="Match Type:" FontWeight="Bold" Margin="0,0,0,12" /><TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedMatchRule.MatchType}" />
                <TextBlock Grid.Row="4" Text="Priority:" FontWeight="Bold" Margin="0,0,0,12" /><TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedMatchRule.Priority}" />
                <TextBlock Grid.Row="5" Text="Status:" FontWeight="Bold" Margin="0,0,0,12" /><TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedMatchRule.Status}" />
                <TextBlock Grid.Row="6" Text="Email Type:" FontWeight="Bold" Margin="0,0,0,12" /><TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedMatchRule.EmailTypeName}" />
                <TextBlock Grid.Row="7" Text="Recipient Mappings:" FontWeight="Bold" Margin="0,0,0,12" /><TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SelectedMatchRule.RecipientMappingCount}" />
                <TextBlock Grid.Row="8" Text="Last Updated:" FontWeight="Bold" /><TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding SelectedMatchRule.LastUpdatedDisplay}" />
            </Grid></StackPanel><StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center"><Button Content="✎  Edit" Width="126" Margin="0,0,14,0" Style="{StaticResource SecondaryOutlineButtonStyle}" Command="{Binding EditSelectedRuleCommand}" AutomationProperties.Name="Edit selected match rule" /><Button Content="♙  View Mappings" Width="150" Style="{StaticResource SecondaryOutlineButtonStyle}" Command="{Binding ViewMappingsCommand}" AutomationProperties.Name="View recipient mappings for selected match rule" /></StackPanel></Grid></Border>
        </Grid>
    </Grid>
</UserControl>
